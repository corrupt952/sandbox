# Copy to .env and fill in. .env is gitignored — never commit real values.
# Create a bot at https://discord.com/developers/applications, enable the
# GUILD_VOICE_STATES intent, and invite it to your server.
DISCORD_BOT_TOKEN=your-bot-token
DISCORD_GUILD_ID=000000000000000000
DISCORD_VOICE_CHANNEL_ID=000000000000000000
